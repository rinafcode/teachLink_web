{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "type-check:all": "pnpm -r --if-present run type-check",
    "lint": "next lint --max-warnings=0",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.jsx . --fix",
    "lint:all": "pnpm -r --if-present run lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:all": "pnpm -r --if-present run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "validate:ui": "node scripts/validate-ui.cjs",
    "validate:web3": "node scripts/validate-web3.cjs",
    "validate": "pnpm run validate:ui && pnpm run validate:web3",
    "check-i18n": "node scripts/check-i18n.cjs",
    "check-locales": "node scripts/check-locales.mjs",
    "prebuild": "pnpm run check-locales && pnpm run check-i18n",
    "postbuild": "pnpm run generate:sitemap",
    "generate:sitemap": "npx tsx scripts/generate-sitemap.ts",
    "migrate": "npx tsx src/lib/db/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "@apollo/client": "^4.2.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@testing-library/dom": "^10.4.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-youtube": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/uuid": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "ethers": "^6.12.0",
    "framer-motion": "^12.42.2",
    "graphql": "^17.0.1",
    "graphql-ws": "^6.0.8",
    "i18next": "^26.3.4",
    "idb": "^8.0.0",
    "jose": "^6.2.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "puppeteer": "^25.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-big-calendar": "1.20.0",
    "react-countdown": "^2.3.6",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.7.0",
    "react-intersection-observer": "^10.0.3",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "reacts-cli": "^1.0.2",
    "recharts": "^3.9.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "video.js": "^8.23.9",
    "videojs-youtube": "^3.0.1",
    "web-push": "^3.6.7",
    "web-vitals": "^5.3.0",
    "workbox-webpack-plugin": "^7.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.4.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.54.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@teachlink/tooling": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/chai": "^5.2.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-big-calendar": "1.16.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-check": "^3.22.0",
    "husky": "^8.0.3",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
