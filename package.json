{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "type-check:all": "pnpm -r --if-present run type-check",
    "lint": "next lint --max-warnings=0",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.jsx . --fix",
    "lint:all": "pnpm -r --if-present run lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:all": "pnpm -r --if-present run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "validate:ui": "node scripts/validate-ui.cjs",
    "validate:web3": "node scripts/validate-web3.cjs",
    "validate": "pnpm run validate:ui && pnpm run validate:web3",
    "check-i18n": "node scripts/check-i18n.cjs",
    "check-locales": "node scripts/check-locales.mjs",
    "prebuild": "pnpm run check-locales && pnpm run check-i18n",
    "postbuild": "pnpm run generate:sitemap",
    "generate:sitemap": "npx tsx scripts/generate-sitemap.ts",
    "migrate": "npx tsx src/lib/db/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "@apollo/client": "^3.8.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@monaco-editor/react": "^4.7.0",
    "@testing-library/dom": "^10.4.1",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-youtube": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.2.4",
    "ethers": "^6.12.0",
    "framer-motion": "^12.23.0",
    "graphql": "^16.8.0",
    "graphql-ws": "^5.14.0",
    "i18next": "^24.0.0",
    "idb": "^8.0.0",
    "jose": "^6.2.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.462.0",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "puppeteer": "^24.42.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-big-calendar": "1.19.4",
    "react-countdown": "^2.3.6",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.60.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^10.0.3",
    "react-virtualized-auto-sizer": "^1.0.7",
    "react-window": "^1.8.9",
    "reacts-cli": "^1.0.2",
    "recharts": "^2.15.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0",
    "uuid": "^14.0.1",
    "video.js": "^8.23.7",
    "videojs-youtube": "^3.0.1",
    "web-push": "^3.6.7",
    "web-vitals": "^4.2.4",
    "workbox-webpack-plugin": "^7.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^3.25.75",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@teachlink/tooling": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.27",
    "@types/react-big-calendar": "1.16.3",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^3.2.6"
  }
}
