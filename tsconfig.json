{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/app/api/auth/**/*",
    "src/app/api/bookmarks/**/*",
    "src/app/api/notes/**/*",
    "src/app/api/certificates/**/*",
    "src/app/components/dashboard/widgets/**/*",
    "src/app/dashboard/page.tsx",
    "src/app/hooks/useMessaging.tsx",
    "src/app/hooks/useNotifications.tsx",
    "src/app/hooks/useStudyGroups.tsx",
    "src/components/BulkActions.tsx",
    "src/components/InfiniteList.tsx",
    "src/components/accessibility/VoiceControl.tsx",
    "src/components/assessment/QuestionTypes.tsx",
    "src/components/audio/AudioPlayer.tsx",
    "src/components/cms/MediaManager.tsx",
    "src/components/navigation/SidebarNavigation.tsx",
    "src/components/notificationcenter.tsx",
    "src/components/virtualizedsearchresults.tsx",
    "src/components/web3/WalletConnector.tsx",
    "src/form-management/**/*",
    "**/useCodeEditor.tsx",
    "**/useCollaboration.ts",
    "**/useLazyLoad.tsx",
    "**/useVideoPlayer.ts",
    "**/useVirtualBackground.ts",
    "**/useWeb3Wallet.ts",
    "**/api.ts",
    "**/apiInterceptors.ts",
    "**/acl.ts",
    "**/bulk/bulkHistory.ts",
    "**/settings/service.ts",
    "**/redirectManagement.ts",
    "**/settings/index.tsx",
    "**/serviceWorker.ts",
    "**/pdf-generation.ts",
    "**/serviceAccount.ts",
    "**/virtualBackgroundUtils.ts",
    "**/sms-cluster-worker.ts"
  ]
}
